{
    "name": "ratorio-tests",
    "private": true,
    "description": "Vitest unit test environment for ratorio ESM migration",
    "scripts": {
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:staging-diff": "vitest run --config vitest.staging.config.ts",
        "scan:undeclared": "node scan-undeclared-writes.mjs"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "@vitest/ui": "^4.1.10",
        "eslint": "^10.7.0",
        "happy-dom": "^20.10.6",
        "playwright": "^1.61.1",
        "tom-select": "^2.6.2",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
