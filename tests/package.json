{
    "name": "ratorio-tests",
    "private": true,
    "description": "Vitest unit test environment for ratorio ESM migration",
    "scripts": {
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:staging-diff": "vitest run --config vitest.staging.config.ts",
        "scan:undeclared": "node scan-undeclared-writes.mjs"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "eslint": "^10.4.1",
        "happy-dom": "^20.6.3",
        "playwright": "^1.53.0",
        "tom-select": "^2.6.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
